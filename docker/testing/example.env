# Developer secrets for docker testing environments.
# Copy this file to .env in the same directory and fill in the values:
#
#   cp docker/testing/example.env docker/testing/.env
#
# Then run tests with:
#
#   tox -e docker-remote          # full run (remote MAPDL + host PyMAPDL)
#   tox -e docker-local           # full run (local MAPDL + host PyMAPDL)
#   tox -e docker-run-remote      # re-run pytest in existing container (no rebuild)
#   tox -e docker-run-local       # re-run pytest in existing container (no rebuild)
#
# The .env file is gitignored and will never be committed.

# -----------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------
ANSYSLMD_LICENSE_FILE=1055@11.22.33.44
DOCKER_IMAGE=myregistry.com/myregistryuser/myansysimage:latest

# -----------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------
# Extra arguments forwarded to pytest inside the container.
# Example: PYTEST_ARGUMENTS=-k test_my_feature --no-cov --maxfail=0
PYTEST_ARGUMENTS=
