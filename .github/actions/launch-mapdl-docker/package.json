{
  "name": "launch-mapdl-docker-action",
  "version": "1.0.0",
  "description": "GitHub Action for launching MAPDL Docker instances",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "esbuild index.js --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js && esbuild post.js --bundle --platform=node --target=node20 --format=cjs --outfile=dist-post/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "actions",
    "mapdl",
    "docker"
  ],
  "author": "Ansys",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.0"
  }
}
